<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgricultureMachineInfoMapper">
    
    <resultMap type="AgricultureMachineInfo" id="AgricultureMachineInfoResult">
        <result property="machineId"    column="machine_id"    />
        <result property="machineCode"    column="machine_code"    />
        <result property="machineName"    column="machine_name"    />
        <result property="machineTypeId"    column="machine_type_id"    />
        <result property="machineTypeName"    column="machine_type_name"    />
        <result property="measureUnit"    column="measure_unit"    />
        <result property="remark"    column="remark"    />
        <result property="status"    column="status"    />
        <result property="orderNum"    column="order_num"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectAgricultureMachineInfoVo">
        select
            ami.machine_id,
            ami.machine_code,
            ami.machine_name,
            ami.machine_type_id,
            amt.machine_type_name,
            ami.measure_unit,
            ami.remark,
            ami.status,
            ami.order_num,
            ami.create_by,
            ami.create_time,
            ami.update_by,
            ami.update_time,
            ami.del_flag
        from agriculture_machine_info ami
        left join agriculture_machine_type amt on ami.machine_type_id = amt.machine_type_id
    </sql>

    <select id="selectAgricultureMachineInfoList" parameterType="AgricultureMachineInfo" resultMap="AgricultureMachineInfoResult">
        <include refid="selectAgricultureMachineInfoVo"/>
        <where>
            <if test="machineCode != null  and machineCode != ''"> and ami.machine_code = #{machineCode}</if>
            <if test="machineName != null  and machineName != ''"> and ami.machine_name like concat('%', #{machineName}, '%')</if>
            <if test="machineTypeId != null  and machineTypeId != ''"> and ami.machine_type_id = #{machineTypeId}</if>
            <if test="measureUnit != null  and measureUnit != ''"> and ami.measure_unit = #{measureUnit}</if>
            <if test="status != null  and status != ''"> and ami.status = #{status}</if>
            <if test="orderNum != null "> and ami.order_num = #{orderNum}</if>
        </where>
    </select>

    <select id="selectAgricultureMachineInfoByMachineId" parameterType="String" resultMap="AgricultureMachineInfoResult">
        <include refid="selectAgricultureMachineInfoVo"/>
        where ami.machine_id = #{machineId}
    </select>

    <insert id="insertAgricultureMachineInfo" parameterType="AgricultureMachineInfo" useGeneratedKeys="true" keyProperty="machineId">
        insert into agriculture_machine_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="machineCode != null and machineCode != ''">machine_code,</if>
            <if test="machineName != null and machineName != ''">machine_name,</if>
            <if test="machineTypeId != null">machine_type_id,</if>
            <if test="measureUnit != null and measureUnit != ''">measure_unit,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="machineCode != null and machineCode != ''">#{machineCode},</if>
            <if test="machineName != null and machineName != ''">#{machineName},</if>
            <if test="machineTypeId != null">#{machineTypeId},</if>
            <if test="measureUnit != null and measureUnit != ''">#{measureUnit},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateAgricultureMachineInfo" parameterType="AgricultureMachineInfo">
        update agriculture_machine_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="machineCode != null and machineCode != ''">machine_code = #{machineCode},</if>
            <if test="machineName != null and machineName != ''">machine_name = #{machineName},</if>
            <if test="machineTypeId != null">machine_type_id = #{machineTypeId},</if>
            <if test="measureUnit != null and measureUnit != ''">measure_unit = #{measureUnit},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
        </trim>
        where machine_id = #{machineId}
    </update>

    <delete id="deleteAgricultureMachineInfoByMachineId" parameterType="String">
        delete from agriculture_machine_info where machine_id = #{machineId}
    </delete>

    <delete id="deleteAgricultureMachineInfoByMachineIds" parameterType="String">
        delete from agriculture_machine_info where machine_id in 
        <foreach item="machineId" collection="array" open="(" separator="," close=")">
            #{machineId}
        </foreach>
    </delete>
</mapper>