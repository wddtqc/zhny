<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgricultureMaterialInfoMapper">
    
    <resultMap type="AgricultureMaterialInfo" id="AgricultureMaterialInfoResult">
        <result property="materialId"    column="material_id"    />
        <result property="materialCode"    column="material_code"    />
        <result property="materialName"    column="material_name"    />
        <result property="materialTypeId"    column="material_type_id"    />
        <result property="materialTypeName"    column="material_type_name"    />
        <result property="measureUnit"    column="measure_unit"    />
        <result property="remark"    column="remark"    />
        <result property="status"    column="status"    />
        <result property="orderNum"    column="order_num"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectAgricultureMaterialInfoVo">
        select
            ami.material_id,
            ami.material_code,
            ami.material_name,
            ami.material_type_id,
            amt.material_type_name,
            ami.measure_unit,
            ami.remark,
            ami.status,
            ami.order_num,
            ami.create_by,
            ami.create_time,
            ami.update_by,
            ami.update_time,
            ami.del_flag
        from agriculture_material_info ami
        left join agriculture_material_type amt on ami.material_type_id = amt.material_type_id
    </sql>

    <select id="selectAgricultureMaterialInfoList" parameterType="AgricultureMaterialInfo" resultMap="AgricultureMaterialInfoResult">
        <include refid="selectAgricultureMaterialInfoVo"/>
        <where>
            <if test="materialCode != null  and materialCode != ''"> and ami.material_code = #{materialCode}</if>
            <if test="materialName != null  and materialName != ''"> and ami.material_name like concat('%', #{materialName}, '%')</if>
            <if test="materialTypeId != null  and materialTypeId != ''"> and ami.material_type_id = #{materialTypeId}</if>
            <if test="measureUnit != null  and measureUnit != ''"> and ami.measure_unit = #{measureUnit}</if>
            <if test="status != null  and status != ''"> and ami.status = #{status}</if>
            <if test="orderNum != null "> and ami.order_num = #{orderNum}</if>
        </where>
    </select>

    <select id="selectAgricultureMaterialInfoByMaterialId" parameterType="String" resultMap="AgricultureMaterialInfoResult">
        <include refid="selectAgricultureMaterialInfoVo"/>
        where ami.material_id = #{materialId}
    </select>

    <insert id="insertAgricultureMaterialInfo" parameterType="AgricultureMaterialInfo" useGeneratedKeys="true" keyProperty="materialId">
        insert into agriculture_material_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="materialCode != null and materialCode != ''">material_code,</if>
            <if test="materialName != null and materialName != ''">material_name,</if>
            <if test="materialTypeId != null">material_type_id,</if>
            <if test="measureUnit != null and measureUnit != ''">measure_unit,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="materialCode != null and materialCode != ''">#{materialCode},</if>
            <if test="materialName != null and materialName != ''">#{materialName},</if>
            <if test="materialTypeId != null">#{materialTypeId},</if>
            <if test="measureUnit != null and measureUnit != ''">#{measureUnit},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateAgricultureMaterialInfo" parameterType="AgricultureMaterialInfo">
        update agriculture_material_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="materialCode != null and materialCode != ''">material_code = #{materialCode},</if>
            <if test="materialName != null and materialName != ''">material_name = #{materialName},</if>
            <if test="materialTypeId != null">material_type_id = #{materialTypeId},</if>
            <if test="measureUnit != null and measureUnit != ''">measure_unit = #{measureUnit},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
        </trim>
        where material_id = #{materialId}
    </update>

    <delete id="deleteAgricultureMaterialInfoByMaterialId" parameterType="String">
        delete from agriculture_material_info where material_id = #{materialId}
    </delete>

    <delete id="deleteAgricultureMaterialInfoByMaterialIds" parameterType="String">
        delete from agriculture_material_info where material_id in 
        <foreach item="materialId" collection="array" open="(" separator="," close=")">
            #{materialId}
        </foreach>
    </delete>
</mapper>