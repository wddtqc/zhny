<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgricultureGermplasmMapper">
    
    <resultMap type="AgricultureGermplasm" id="AgricultureGermplasmResult">
        <result property="germplasmId"    column="germplasm_id"    />
        <result property="cropName"    column="crop_name"    />
        <result property="cropEnName"    column="crop_en_name"    />
        <result property="germplasmName"    column="germplasm_name"    />
        <result property="germplasmEnName"    column="germplasm_en_name"    />
        <result property="germplasmImg"    column="germplasm_img"    />
        <result property="germplasmDes"    column="germplasm_des"    />
        <result property="remark"    column="remark"    />
        <result property="status"    column="status"    />
        <result property="orderNum"    column="order_num"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectAgricultureGermplasmVo">
        select germplasm_id, crop_name, crop_en_name, germplasm_name, germplasm_en_name, germplasm_img, germplasm_des, remark, status, order_num, create_by, create_time, update_by, update_time, del_flag from agriculture_germplasm
    </sql>

    <select id="selectAgricultureGermplasmList" parameterType="AgricultureGermplasm" resultMap="AgricultureGermplasmResult">
        <include refid="selectAgricultureGermplasmVo"/>
        <where>  
            <if test="cropName != null  and cropName != ''"> and crop_name like concat('%', #{cropName}, '%')</if>
            <if test="cropEnName != null  and cropEnName != ''"> and crop_en_name like concat('%', #{cropEnName}, '%')</if>
            <if test="germplasmName != null  and germplasmName != ''"> and germplasm_name like concat('%', #{germplasmName}, '%')</if>
            <if test="germplasmEnName != null  and germplasmEnName != ''"> and germplasm_en_name like concat('%', #{germplasmEnName}, '%')</if>
            <if test="germplasmImg != null  and germplasmImg != ''"> and germplasm_img = #{germplasmImg}</if>
            <if test="germplasmDes != null  and germplasmDes != ''"> and germplasm_des = #{germplasmDes}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="orderNum != null "> and order_num = #{orderNum}</if>
        </where>
    </select>
    
    <select id="selectAgricultureGermplasmByGermplasmId" parameterType="String" resultMap="AgricultureGermplasmResult">
        <include refid="selectAgricultureGermplasmVo"/>
        where germplasm_id = #{germplasmId}
    </select>

    <insert id="insertAgricultureGermplasm" parameterType="AgricultureGermplasm" useGeneratedKeys="true" keyProperty="germplasmId">
        insert into agriculture_germplasm
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="cropName != null and cropName != ''">crop_name,</if>
            <if test="cropEnName != null and cropEnName != ''">crop_en_name,</if>
            <if test="germplasmName != null and germplasmName != ''">germplasm_name,</if>
            <if test="germplasmEnName != null and germplasmEnName != ''">germplasm_en_name,</if>
            <if test="germplasmImg != null and germplasmImg != ''">germplasm_img,</if>
            <if test="germplasmDes != null and germplasmDes != ''">germplasm_des,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="cropName != null and cropName != ''">#{cropName},</if>
            <if test="cropEnName != null and cropEnName != ''">#{cropEnName},</if>
            <if test="germplasmName != null and germplasmName != ''">#{germplasmName},</if>
            <if test="germplasmEnName != null and germplasmEnName != ''">#{germplasmEnName},</if>
            <if test="germplasmImg != null and germplasmImg != ''">#{germplasmImg},</if>
            <if test="germplasmDes != null and germplasmDes != ''">#{germplasmDes},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateAgricultureGermplasm" parameterType="AgricultureGermplasm">
        update agriculture_germplasm
        <trim prefix="SET" suffixOverrides=",">
            <if test="cropName != null and cropName != ''">crop_name = #{cropName},</if>
            <if test="cropEnName != null and cropEnName != ''">crop_en_name = #{cropEnName},</if>
            <if test="germplasmName != null and germplasmName != ''">germplasm_name = #{germplasmName},</if>
            <if test="germplasmEnName != null and germplasmEnName != ''">germplasm_en_name = #{germplasmEnName},</if>
            <if test="germplasmImg != null and germplasmImg != ''">germplasm_img = #{germplasmImg},</if>
            <if test="germplasmDes != null and germplasmDes != ''">germplasm_des = #{germplasmDes},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
        </trim>
        where germplasm_id = #{germplasmId}
    </update>

    <delete id="deleteAgricultureGermplasmByGermplasmId" parameterType="String">
        delete from agriculture_germplasm where germplasm_id = #{germplasmId}
    </delete>

    <delete id="deleteAgricultureGermplasmByGermplasmIds" parameterType="String">
        delete from agriculture_germplasm where germplasm_id in 
        <foreach item="germplasmId" collection="array" open="(" separator="," close=")">
            #{germplasmId}
        </foreach>
    </delete>
</mapper>