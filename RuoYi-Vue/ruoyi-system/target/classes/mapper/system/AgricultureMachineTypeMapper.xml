<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgricultureMachineTypeMapper">
    
    <resultMap type="AgricultureMachineType" id="AgricultureMachineTypeResult">
        <result property="machineTypeId"    column="machine_type_id"    />
        <result property="machineTypeName"    column="machine_type_name"    />
        <result property="remark"    column="remark"    />
        <result property="status"    column="status"    />
        <result property="orderNum"    column="order_num"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectAgricultureMachineTypeVo">
        select machine_type_id, machine_type_name, remark, status, order_num, create_by, create_time, update_by, update_time, del_flag from agriculture_machine_type
    </sql>

    <select id="selectAgricultureMachineTypeList" parameterType="AgricultureMachineType" resultMap="AgricultureMachineTypeResult">
        <include refid="selectAgricultureMachineTypeVo"/>
        <where>  
            <if test="machineTypeName != null  and machineTypeName != ''"> and machine_type_name like concat('%', #{machineTypeName}, '%')</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="orderNum != null "> and order_num = #{orderNum}</if>
        </where>
    </select>
    
    <select id="selectAgricultureMachineTypeByMachineTypeId" parameterType="String" resultMap="AgricultureMachineTypeResult">
        <include refid="selectAgricultureMachineTypeVo"/>
        where machine_type_id = #{machineTypeId}
    </select>

    <insert id="insertAgricultureMachineType" parameterType="AgricultureMachineType" useGeneratedKeys="true" keyProperty="machineTypeId">
        insert into agriculture_machine_type
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="machineTypeName != null and machineTypeName != ''">machine_type_name,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="machineTypeName != null and machineTypeName != ''">#{machineTypeName},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateAgricultureMachineType" parameterType="AgricultureMachineType">
        update agriculture_machine_type
        <trim prefix="SET" suffixOverrides=",">
            <if test="machineTypeName != null and machineTypeName != ''">machine_type_name = #{machineTypeName},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
        </trim>
        where machine_type_id = #{machineTypeId}
    </update>

    <delete id="deleteAgricultureMachineTypeByMachineTypeId" parameterType="String">
        delete from agriculture_machine_type where machine_type_id = #{machineTypeId}
    </delete>

    <delete id="deleteAgricultureMachineTypeByMachineTypeIds" parameterType="String">
        delete from agriculture_machine_type where machine_type_id in 
        <foreach item="machineTypeId" collection="array" open="(" separator="," close=")">
            #{machineTypeId}
        </foreach>
    </delete>
</mapper>